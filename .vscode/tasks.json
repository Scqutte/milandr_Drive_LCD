{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build firmware",
            "type": "shell",
            "command": "make",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Flash firmware",
            "type": "shell",
            "command": "openocd",
            "args": [
                "-s",
                "${workspaceFolder}",
                "-f",
                "openocd/openocd_flash.cfg",
                "-c",
                "program build/milandr_test.elf verify reset exit"
            ],
            "dependsOn": "Build firmware",
            "problemMatcher": []
        }
    ]
}
